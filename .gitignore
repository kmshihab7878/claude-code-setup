# Runtime / ephemeral state
state/
sessions/
session-env/
shell-snapshots/
cache/
contexts/
paste-cache/
stats-cache.json
statsig/
telemetry/
vercel-plugin-*
mcp-needs-auth-cache.json
ide/
debug/
downloads/
worktrees/
backups/
file-history/
tasks/
todos/
plans/
tools/

# Private per-project memory (contains conversation context)
projects/

# Audit, history, and telemetry logs (private)
audit.log
audit-mcp.log
history.jsonl
usage.jsonl
mcp-snapshot-*.txt

# Evolution layer — raw evidence is private/ephemeral
evolution/records/*.jsonl
evolution/disabled

# Secrets and credentials
settings.local.json
*.backup.*
.env
*.pem
*.key

# Claude Code runtime
metrics/
skills-audit/

# OS
.DS_Store

# Python bytecode / caches (must not leak local paths via .pyc)
__pycache__/
*.pyc
*.pyo

# Nested git repos (skills pulled from upstream should not carry their own .git)
skills/*/.git/

# Private-product skills — never commit a `hue`-generated skill that exposes
# a private project's design language, brand vocabulary, or page structure.
# Add patterns here as new private products surface.
skills/shihab-task-mgmt/
