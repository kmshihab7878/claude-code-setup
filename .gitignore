# Runtime / ephemeral state
state/
sessions/
session-env/
shell-snapshots/
cache/
contexts/
paste-cache/
stats-cache.json
statsig/
telemetry/
vercel-plugin-*
mcp-needs-auth-cache.json
ide/
debug/
downloads/
worktrees/
backups/
file-history/
tasks/
todos/
plans/
tools/

# Private per-project memory (contains conversation context)
projects/

# Audit, history, and telemetry logs (private)
audit.log
audit-mcp.log
history.jsonl
usage.jsonl
mcp-snapshot-*.txt

# Evolution layer — raw evidence is private/ephemeral
evolution/records/*.jsonl
evolution/disabled

# Secrets and credentials
settings.local.json
*.backup.*
.env
*.pem
*.key

# Claude Code runtime
metrics/
skills-audit/

# OS
.DS_Store

# Python bytecode / caches (must not leak local paths via .pyc)
__pycache__/
*.pyc
*.pyo

# Nested git repos (skills pulled from upstream should not carry their own .git)
skills/*/.git/

# AI OS — cloned external reference repos (kept out of source tree)
references/external/*/repo/

# AI OS — operator's personal context (filled by /onboard, may contain sensitive notes)
# NOTE: the placeholder context/* files in this repo are public-safe; uncomment
# the next line if you fork this repo for personal use and want to keep your
# filled-in answers private.
# context/
