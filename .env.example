# .env.example — Placeholder credentials only. NEVER paste real values here.
#
# Copy this file to `.env` (gitignored) and fill in real values locally.
# `.env` is in .gitignore — verify with: git check-ignore -v .env
#
# Naming: AIOS_<DOMAIN>_<TOOL>_<FIELD>
# Example: AIOS_REVENUE_STRIPE_RESTRICTED_KEY=sk_live_...
#
# Use dedicated AI OS service accounts for sensitive tools — not your personal account.

# ----------------------------------------------------------------
# Revenue
# ----------------------------------------------------------------
AIOS_REVENUE_STRIPE_RESTRICTED_KEY=
AIOS_REVENUE_STRIPE_WEBHOOK_SECRET=

# ----------------------------------------------------------------
# Customer / CRM
# ----------------------------------------------------------------
AIOS_CUSTOMER_CRM_API_KEY=
AIOS_CUSTOMER_CRM_BASE_URL=

# ----------------------------------------------------------------
# Calendar
# ----------------------------------------------------------------
# OAuth is preferred; populate only if using direct API instead of MCP.
AIOS_CALENDAR_GOOGLE_CLIENT_ID=
AIOS_CALENDAR_GOOGLE_CLIENT_SECRET=

# ----------------------------------------------------------------
# Comms (Email / Slack / etc.)
# ----------------------------------------------------------------
AIOS_COMMS_RESEND_API_KEY=
AIOS_COMMS_SLACK_BOT_TOKEN=
AIOS_COMMS_SLACK_SIGNING_SECRET=

# ----------------------------------------------------------------
# Tasks (Linear / Notion / Things / Asana)
# ----------------------------------------------------------------
AIOS_TASKS_LINEAR_API_KEY=
AIOS_TASKS_NOTION_API_KEY=

# ----------------------------------------------------------------
# Meetings (Granola / Otter / Fireflies / Meet recordings)
# ----------------------------------------------------------------
AIOS_MEETINGS_GRANOLA_API_KEY=
AIOS_MEETINGS_FIREFLIES_API_KEY=

# ----------------------------------------------------------------
# Knowledge (Notion / Obsidian / Custom)
# ----------------------------------------------------------------
AIOS_KNOWLEDGE_NOTION_API_KEY=
AIOS_KNOWLEDGE_OBSIDIAN_VAULT_PATH=

# ----------------------------------------------------------------
# Misc — observability, search, etc.
# ----------------------------------------------------------------
AIOS_SEARCH_TAVILY_API_KEY=
AIOS_SEARCH_BRAVE_API_KEY=
AIOS_OBSERVABILITY_GRAFANA_TOKEN=
